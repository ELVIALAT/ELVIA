# =============================================================================
# BACKEND — Variables de entorno
# Copiar como .env y completar los valores
# NUNCA commitear el archivo .env — está en .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# SUPABASE (nuevo proyecto elvia-b2b-prod)
# Obtener en: https://supabase.com → Project → Settings → API
# -----------------------------------------------------------------------------
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_ANON_KEY=<anon-public-key>
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>   # Solo backend — NUNCA al frontend

# -----------------------------------------------------------------------------
# IA — Anthropic / Claude
# Escritura creativa de alta calidad: optimizeCV, matchCVtoJob, Factoría Harvard
# Obtener en: https://console.anthropic.com → API Keys
# -----------------------------------------------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MODEL_FAST=claude-haiku-4-5-20251001

# -----------------------------------------------------------------------------
# IA — DeepSeek V3
# Extracción JSON, clasificación, chat ELVIA (~70% más barato que Haiku)
# Obtener en: https://platform.deepseek.com → API Keys
# -----------------------------------------------------------------------------
DEEPSEEK_API_KEY=sk-...

# -----------------------------------------------------------------------------
# IA — OpenAI
# Obtener en: https://platform.openai.com → API Keys
# -----------------------------------------------------------------------------
OPENAI_API_KEY=sk-...

# -----------------------------------------------------------------------------
# IA — Google Gemini
# Obtener en: https://aistudio.google.com → Get API Key
# -----------------------------------------------------------------------------
GEMINI_API_KEY=AIza...

# -----------------------------------------------------------------------------
# EMAIL — Resend
# Obtener en: https://resend.com → API Keys
# Dominio verificado requerido para producción
# -----------------------------------------------------------------------------
RESEND_API_KEY=re_...

# -----------------------------------------------------------------------------
# SERVIDOR
# -----------------------------------------------------------------------------
PORT=3001
NODE_ENV=development

# URL del frontend (para CORS y construcción de links en emails)
FRONTEND_URL=http://localhost:5173
# Producción: FRONTEND_URL=https://empresas-v2.elvia.lat

# -----------------------------------------------------------------------------
# MONITOREO — Sentry
# Obtener DSN en: https://sentry.io → Project → Settings → Client Keys (DSN)
# Dejar vacío en desarrollo local
# -----------------------------------------------------------------------------
SENTRY_DSN=https://...@o...ingest.sentry.io/...

# -----------------------------------------------------------------------------
# SEGURIDAD — Cron/Admin endpoint protection
# Generar con: openssl rand -hex 32
# -----------------------------------------------------------------------------
CRON_SECRET=<random-64-chars>

# -----------------------------------------------------------------------------
# LÍMITES DE GASTO IA (protección anti-abuso)
# Valores en USD. Dejar vacío para sin límite (no recomendado en producción)
# -----------------------------------------------------------------------------
AI_DAILY_BUDGET_USD=10
AI_PER_TENANT_DAILY_LIMIT_USD=5
AI_PER_USER_DAILY_LIMIT_USD=1

# -----------------------------------------------------------------------------
# JOOBLE (búsqueda de vacantes)
# Obtener en: https://jooble.org/api/about
# -----------------------------------------------------------------------------
JOOBLE_API_KEY=
