# =============================================================================
# FRONTEND — Variables de entorno (Vite)
# Copiar como .env y completar los valores
# Solo variables con prefijo VITE_ son expuestas al bundle del navegador
# NUNCA commitear el archivo .env — está en .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# BACKEND
# Desarrollo: http://localhost:3001
# Producción: URL de Railway del nuevo servicio
# -----------------------------------------------------------------------------
VITE_API_URL=http://localhost:3001

# -----------------------------------------------------------------------------
# SUPABASE — claves públicas (seguras para el frontend)
# Obtener en: https://supabase.com → Project → Settings → API
# Usar el proyecto elvia-b2b-staging en desarrollo, elvia-b2b-prod en producción
# -----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>

# -----------------------------------------------------------------------------
# MONITOREO — Sentry (frontend)
# DSN diferente al del backend — crear proyecto separado en Sentry
# Dejar vacío en desarrollo local
# -----------------------------------------------------------------------------
VITE_SENTRY_DSN=https://...@o...ingest.sentry.io/...

# -----------------------------------------------------------------------------
# SEGURIDAD — Cloudflare Turnstile (captcha)
# Obtener en: https://dash.cloudflare.com → Turnstile → Add site
# En desarrollo usar la test key: 1x00000000000000000000AA (siempre pasa)
# -----------------------------------------------------------------------------
VITE_TURNSTILE_SITE_KEY=1x00000000000000000000AA

# -----------------------------------------------------------------------------
# ENTORNO
# Valores: development | staging | production
# Vite expone esto también en import.meta.env.MODE automáticamente
# -----------------------------------------------------------------------------
VITE_APP_ENV=development

# -----------------------------------------------------------------------------
# TENANT
# Para el bundle B2B siempre es "b2b"
# Permite al frontend saber qué config de tenant cargar
# -----------------------------------------------------------------------------
VITE_TENANT_TYPE=b2b
