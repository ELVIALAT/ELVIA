# Dependencias
node_modules/

# Lockfile raíz del monorepo: NO se commitea. Los deploys instalan por
# subdirectorio (Netlify base=apps/web, Railway cd services/api), así que el
# lockfile de cada workspace (apps/web, services/api) es la fuente de verdad.
# Un lockfile raíz sería redundante y propenso a drift en este modelo.
/package-lock.json

# Variables de entorno — nunca subir al repo
.env
.env.*
!.env.example

# Builds
dist/
build/

# Archivos de sistema
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*

# Archivos temporales de upload
uploads/

# Claude Code local configuration
.claude/
.claude-flow/
.mcp.json
.claude/settings.local.json

# Propuestas comerciales (documentos internos)
docs/*.html

# Logos marca consultora APAZ (no pertenecen a la plataforma ELVIA)
apps/web/public/LOGOS/Logo APAZ Talent Search*

# Artefactos de herramientas de desarrollo local (no pertenecen al repo)
.agent/
.agents/
.swarm/
.codex/
AGENTS.md

# Supabase CLI — archivos temporales locales
supabase/.temp/
